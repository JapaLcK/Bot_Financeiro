# ─────────────────────────────────────────────────────────────────────────────
# FinBot — Variáveis de Ambiente
# Copie este arquivo para `.env` ou `.env.staging` e preencha os valores.
# No Railway: adicione cada variável em Settings → Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Ambiente lógico opcional. Ex.:
# APP_ENV=prod     -> carrega `.env`
# APP_ENV=staging  -> carrega `.env` + `.env.staging`
APP_ENV=dev

# ── Banco de Dados ────────────────────────────────────────────────────────────
# URL de conexão PostgreSQL (Railway preenche automaticamente se você
# adicionar um serviço PostgreSQL ao projeto).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Dashboard ─────────────────────────────────────────────────────────────────
# URL pública do serviço (Railway preenche após o primeiro deploy).
# Ex: https://dashboard-production-020d.up.railway.app
DASHBOARD_URL=https://seu-projeto.up.railway.app

# Fuso horário para exibição de datas no dashboard.
TZ=America/Sao_Paulo

# Intervalo (segundos) de atualização automática via WebSocket.
POLL_INTERVAL=30

# ── Privacidade / exclusão de conta ──────────────────────────────────────────
# Limite de contas removidas por execução do job dedicado no Railway.
ACCOUNT_DELETION_JOB_LIMIT=50

# E-mail público exibido nos avisos de suporte.
SUPPORT_EMAIL=contato@pigbankai.com

# ── Autenticação (JWT) ────────────────────────────────────────────────────────
# Segredo para assinar tokens JWT. Use uma string longa e aleatória.
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria

# ── Painel Admin Privado ─────────────────────────────────────────────────────
# Credenciais exclusivas do painel administrativo interno.
# Configure SOMENTE no ambiente do deploy ou no seu .env local, nunca no repositório.
ADMIN_DASHBOARD_USERNAME=admin
# Use uma das duas opções abaixo:
ADMIN_DASHBOARD_PASSWORD=troque-por-uma-senha-forte
# ADMIN_DASHBOARD_PASSWORD_HASH=$2b$12$...
ADMIN_DASHBOARD_SESSION_HOURS=12

# ── Bot Discord ───────────────────────────────────────────────────────────────
# Para staging, crie um segundo bot/aplicação no Discord Developer Portal
# e use outro token para não responder no servidor de produção.
DISCORD_BOT_TOKEN=seu-token-do-discord-aqui

# ── Bot WhatsApp (Meta Cloud API) ─────────────────────────────────────────────
# Número público do bot no formato internacional, sem + e sem espaços.
# Usado para montar links wa.me após o cadastro.
WHATSAPP_NUMBER=5511999999999

# Token de acesso da Meta com permissões de WhatsApp Business.
WA_TOKEN=EAAB...

# ID técnico do número no WhatsApp Cloud API (phone_number_id).
WA_PHONE_NUMBER_ID=123456789012345

# Token de verificação usado pela Meta no GET do webhook.
WA_VERIFY_TOKEN=seu_verify_token_aqui

# App Secret da Meta para validar assinatura do webhook recebido.
WA_APP_SECRET=seu_app_secret_aqui

# Versão da Graph API da Meta.
WA_GRAPH_VERSION=v25.0

# Template aprovado na Meta para mensagem proativa no WhatsApp.
# Fora da janela de 24h, o WhatsApp aceita apenas templates aprovados; mensagens
# comuns enviadas logo depois do template ainda falham com erro 131047.
# Exemplo de texto do template aprovado:
# "Olá! Tenho uma atualização financeira do PigBank AI para você."
WA_PROACTIVE_TEMPLATE_NAME=
WA_PROACTIVE_TEMPLATE_LANGUAGE=pt_BR

# Se o template aprovado tiver placeholders nomeados no corpo, por exemplo:
# {{saldo}}, {{gastos}}, {{receita}} e {{lancamentos}},
# habilite esta opção para enviar os valores dentro do próprio template.
WA_PROACTIVE_TEMPLATE_INCLUDE_REPORT=0

# Se o template aprovado tiver um botão de resposta rápida "Parar resumo",
# habilite esta opção para enviar o payload que o bot usa para cancelar.
WA_PROACTIVE_TEMPLATE_STOP_BUTTON=0

# Template aprovado na Meta para campanhas curtas de atualizações do Piggy.
# Usado por scripts/send_update_whatsapp.py.
WA_UPDATE_TEMPLATE_NAME=atualizacao_pigbank
WA_UPDATE_TEMPLATE_LANGUAGE=pt_BR

# Se o template de atualização tiver um botão de resposta rápida para parar
# atualizações, habilite para enviar o payload tratado pelo webhook.
WA_UPDATE_TEMPLATE_STOP_BUTTON=0

# Endpoints e simulacao local do WhatsApp.
# ENABLE_DEV_ENDPOINTS registra /wa/dev/simulate apenas em dev/staging.
# WA_SIMULATION_ONLY faz /wa/dev/simulate apenas extrair/retornar mensagens,
# sem processar comandos, gravar no banco ou enviar resposta pelo WhatsApp.
ENABLE_DEV_ENDPOINTS=0
WA_SIMULATION_ONLY=0

# ── Investimentos ────────────────────────────────────────────────────────────
# Atualiza automaticamente os saldos de investimentos em background.
# O cálculo só avança quando há taxa oficial nova disponível (CDI/Selic/IPCA).
INVESTMENT_ACCRUAL_INTERVAL_HOURS=6
INVESTMENT_ACCRUAL_STARTUP_DELAY_SECONDS=90

# ── IA (OpenAI) ───────────────────────────────────────────────────────────────
# Necessário para categorização por IA (fallback automático).
# Deixe em branco para usar apenas as regras locais.
OPENAI_API_KEY=sk-...

# ── Stripe (Pagamentos) ───────────────────────────────────────────────────────
# 1. Crie uma conta em https://stripe.com
# 2. Vá em Developers → API Keys para obter a Secret Key
# 3. Crie um produto + preço recorrente (mensal) e copie o Price ID
# 4. Configure um webhook em Developers → Webhooks apontando para:
#    https://seu-projeto.up.railway.app/billing/webhook
#    Eventos necessários: checkout.session.completed, invoice.paid,
#    invoice.payment_failed, customer.subscription.deleted
# 5. Copie o Signing Secret do webhook

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# ── Pluggy / Open Finance ───────────────────────────────────────────────────
# Use client id/secret somente no backend. Nunca coloque estas chaves no HTML.
PLUGGY_CLIENT_ID=seu_client_id
PLUGGY_CLIENT_SECRET=seu_client_secret
PLUGGY_BASE_URL=https://api.pluggy.ai
# Opcional: se preenchida, reutiliza uma API Key Pluggy existente.
# Se ficar vazia, o backend gera uma API Key temporária via client id/secret.
PLUGGY_API_KEY=
PLUGGY_PRODUCTS=ACCOUNTS,TRANSACTIONS,CREDIT_CARDS
PLUGGY_INCLUDE_SANDBOX=1
# Opcional em produção. Se vazio e DASHBOARD_URL for https, usa:
# {DASHBOARD_URL}/open-finance/pluggy/webhook
PLUGGY_WEBHOOK_URL=
PLUGGY_WEBHOOK_SECRET=

# ── Google OAuth (Login com Google) ──────────────────────────────────────────
# Como obter:
# 1. Acesse https://console.cloud.google.com/apis/credentials
# 2. Crie uma credencial "OAuth client ID" do tipo "Web application"
# 3. Em "Authorized redirect URIs", adicione:
#      https://seu-dominio/auth/google/callback
#      http://localhost:8000/auth/google/callback   (para dev)
# 4. Copie o Client ID e Client Secret abaixo.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://seu-dominio/auth/google/callback

# ── Opcional ──────────────────────────────────────────────────────────────────
# ID do usuário padrão do dashboard (auto-detectado se omitido).
# DASHBOARD_USER_ID=1
